# Copy to .env and fill in. Never commit .env.
# See README.md for where to obtain each key.

# --- Event Registry (news + events) https://eventregistry.org/ (same stack as newsapi.ai) ---
EVENTREGISTRY_API_KEY=

# --- Google Cloud: BigQuery (GDELT) OR general cloud APIs ---
# Path to service account JSON (recommended for server-style runs)
GOOGLE_APPLICATION_CREDENTIALS=
# Or leave empty and use `gcloud auth application-default login` for local dev
GOOGLE_CLOUD_PROJECT=

# --- YouTube Data API (optional: video titles/descriptions) ---
# Create in Google Cloud Console > APIs & Services > Credentials
YOUTUBE_DATA_API_KEY=

# --- OpenAI (optional: embeddings for similarity layer; or use local model later) ---
OPENAI_API_KEY=

# --- Sketch Engine: My account → Generate API key; Basic auth = user + key ---
# https://www.sketchengine.eu/documentation/api-documentation/
SKETCH_ENGINE_USER=
SKETCH_ENGINE_KEY=
# Optional: corpus for `python -m pipeline sketch-ping` (use your hrWac id from the UI)
# SKETCH_DEFAULT_CORP=preloaded/bnc2

# --- Output directories (optional overrides) ---
# PIPELINE_DATA_DIR=./data
